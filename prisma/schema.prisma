generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("vista")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects      ProjectAccess[]
  accounts      Account[]
  sessions      Session[]
  investments   Investor[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id            String   @id @default(cuid())
  name          String
  type          String
  status        String   @default("activo")
  buyPrice      Float
  salePrice     Float?
  listingPrice  Float?
  address       String?
  buyDate       DateTime
  saleDate      DateTime?
  buyerName     String?
  lastUpdate    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  costs         Cost[]
  expenses      Expense[]
  investors     Investor[]
  access        ProjectAccess[]
  timeline      TimelineEvent[]
}

model Cost {
  id           String   @id @default(cuid())
  projectId    String
  concept      String
  amount       Float
  currency     String   @default("USD")
  exchangeRate Float?
  amountUsd    Float?
  category     String
  costType     String
  date         DateTime
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Investor {
  id                String  @id @default(cuid())
  projectId         String
  userId            String?
  name              String
  capitalPercentage Float
  profitPercentage  Float   @default(0)
  amountInvested    Float   @default(0)

  project           Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user              User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  expenses          Expense[]
}

model ProjectAccess {
  id        String  @id @default(cuid())
  projectId String
  userId    String
  role      String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model TimelineEvent {
  id        String   @id @default(cuid())
  projectId String
  action    String
  detail    String
  date      DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Expense {
  id                String   @id @default(cuid())
  projectId         String
  paidByInvestorId  String?
  concept           String
  amount            Float
  currency          String   @default("ARS")
  exchangeRate      Float?
  amountUsd         Float?
  period            DateTime
  paidDate          DateTime?
  receiptUrl        String?
  receiptName       String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paidByInvestor    Investor? @relation(fields: [paidByInvestorId], references: [id], onDelete: SetNull)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "cost_added", "expense_added", "sale_registered", "access_granted"
  message   String
  projectId String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
