# Database
DATABASE_URL="postgresql://user:password@localhost:5432/negocios_db"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic API (for receipt OCR with Claude Vision)
ANTHROPIC_API_KEY="your-anthropic-api-key-here"

# Demo credentials (ONLY for development/staging - NEVER set in production)
# Set NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=true ONLY in dev environments
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false
NEXT_PUBLIC_DEMO_EMAIL=""
NEXT_PUBLIC_DEMO_PASS=""
